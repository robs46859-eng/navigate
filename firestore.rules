rules_version = '2';
// Navigate Mama — deploy: firebase deploy --only firestore:rules
// Perplexity checklist #15: never use allow read, write: if true for production.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Places: adjust if clients write reviews server-side only; public read is common for POI data.
    match /places/{placeId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
